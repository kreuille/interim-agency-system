# ===========================================================================
# Variables d'environnement — exemple. Copier en `.env` et adapter localement.
# JAMAIS committer `.env`. Jamais de secret de prod dans ce fichier.
# ===========================================================================

# --- API ---
VERSION=0.0.0-local
PORT=3000
NODE_ENV=development

# --- Base de données (docker compose) ---
DATABASE_URL=postgresql://dev:dev@localhost:5432/interim_dev?schema=public

# --- Redis (queues BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- SMTP local (MailHog) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@agence-interim.local

# --- MovePlanner (mock local) ---
MOVEPLANNER_BASE_URL=http://localhost:3030
MOVEPLANNER_API_KEY=dev-mock-api-key
MOVEPLANNER_WEBHOOK_SECRET=dev-mock-secret

# --- Auth (Firebase — placeholder) ---
FIREBASE_PROJECT_ID=interim-dev-placeholder
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=./apps/api/secrets/firebase-dev.json

# --- Object storage (placeholder) ---
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=interim-dev-documents
OBJECT_STORAGE_ACCESS_KEY=dev
OBJECT_STORAGE_SECRET_KEY=dev
