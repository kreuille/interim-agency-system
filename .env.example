# ===========================================================================
# Variables d'environnement — exemple. Copier en `.env` et adapter localement.
# JAMAIS committer `.env`. Jamais de secret de prod dans ce fichier.
# ===========================================================================

# --- API ---
VERSION=0.0.0-local
PORT=3000
NODE_ENV=development

# --- Base de données (docker compose) ---
DATABASE_URL=postgresql://dev:dev@localhost:5432/interim_dev?schema=public

# --- Redis (queues BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- SMTP local (MailHog) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@agence-interim.local

# --- MovePlanner (mock local) ---
MOVEPLANNER_BASE_URL=http://localhost:3030
MOVEPLANNER_API_KEY=dev-mock-api-key
MOVEPLANNER_WEBHOOK_SECRET=dev-mock-secret

# --- Auth (Firebase — placeholder) ---
FIREBASE_PROJECT_ID=interim-dev-placeholder
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=./apps/api/secrets/firebase-dev.json

# --- Object storage ---
# OBJECT_STORAGE_PROVIDER=memory  → in-memory adapter (dev / tests)
# OBJECT_STORAGE_PROVIDER=gcs     → GCS Cloud Storage CMEK (staging/prod)
OBJECT_STORAGE_PROVIDER=memory
GCS_BUCKET_NAME=interim-documents-dev
# Pour CMEK (recommandé prod, conforme nLPD CLAUDE.md §3.4) :
# GCS_KMS_KEY_NAME=projects/<id>/locations/europe-west6/keyRings/<ring>/cryptoKeys/<key>

# --- Antivirus (ClamAV via docker-compose) ---
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=60000

# --- BullMQ (queues asynchrones — scan antivirus, push MP) ---
BULLMQ_REDIS_URL=redis://localhost:6379
