{
  "uid": "payroll-batch",
  "title": "Payroll batch — hebdo",
  "tags": ["interim", "payroll", "batch"],
  "timezone": "Europe/Zurich",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Dernier batch — durée",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "max(payroll_batch_duration_seconds)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 1800 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Workers payés (dernier batch)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "max(payroll_batch_workers_processed_total)", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Échecs (7 derniers jours)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "sum(increase(payroll_batch_failed_total[7d]))", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total CHF brut (dernier batch)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "max(payroll_batch_gross_total_chf)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "currencyCHF" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Batch duration sur 30 jours",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "max(payroll_batch_duration_seconds)",
          "refId": "A",
          "legendFormat": "Duration (s)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 20,
      "type": "logs",
      "title": "Logs batch paie (7 derniers jours)",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 12 },
      "datasource": { "uid": "loki", "type": "loki" },
      "targets": [{ "expr": "{service=\"api\"} |= \"payroll.batch\"", "refId": "A" }],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
