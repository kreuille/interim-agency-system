{
  "uid": "payroll-batch",
  "title": "Payroll batch — hebdo",
  "tags": ["interim", "payroll", "batch"],
  "timezone": "Europe/Zurich",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "1m",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Dernier batch — durée p95 (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(payroll_batch_duration_seconds_bucket[24h])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 1800 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Workers payés (cumul 7j)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(payroll_batch_workers_processed_total[7d]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Échecs paie (7 derniers jours)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(payroll_batch_runs_total{status=\"failed\"}[7d]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Brut total CHF (cumul 7j)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(payroll_batch_gross_rappen_total[7d])) / 100",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyCHF" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Durée batch p50/p95 (30j)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(payroll_batch_duration_seconds_bucket[1h])))",
          "refId": "p50",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(payroll_batch_duration_seconds_bucket[1h])))",
          "refId": "p95",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Runs success vs failed (30j)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (rate(payroll_batch_runs_total[1h]))",
          "refId": "A",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Brut + Retenues sociales (cumul, en Rappen)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(payroll_batch_gross_rappen_total[7d]))",
          "refId": "gross",
          "legendFormat": "Brut (Rappen / 7j)"
        },
        {
          "expr": "sum(increase(payroll_batch_deductions_rappen_total[7d]))",
          "refId": "ded",
          "legendFormat": "Retenues (Rappen / 7j)"
        }
      ]
    },
    {
      "id": 20,
      "type": "logs",
      "title": "Logs batch paie (7 derniers jours)",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 20 },
      "datasource": { "uid": "loki", "type": "loki" },
      "targets": [{ "expr": "{service=~\"api|worker\"} |= \"payroll.batch\"", "refId": "A" }],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
